<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auth.letter.dao.AuthLookupValueDao">

    <resultMap id="BaseResultMap" type="com.auth.letter.entity.AuthLookupValue">
        <id column="id" property="id"/>
        <result column="type_code" property="typeCode"/>
        <result column="item_value" property="itemValue"/>
        <result column="label" property="label"/>
        <result column="parent_id" property="parentId"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="is_active" property="isActive"/>
        <result column="created_time" property="createdTime"/>
    </resultMap>

    <sql id="Base_Column_List">
        id, type_code, item_value, label, parent_id, sort_order, is_active, created_time
    </sql>

    <select id="selectByTypeCode" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM auth_lookup_value
        WHERE type_code = #{typeCode}
        AND is_active = TRUE
        ORDER BY sort_order
    </select>

    <select id="selectByTypeCodeAndParentId" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM auth_lookup_value
        WHERE type_code = #{typeCode}
        AND parent_id = #{parentId}
        AND is_active = TRUE
        ORDER BY sort_order
    </select>

    <select id="selectById" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM auth_lookup_value
        WHERE id = #{id}
    </select>

    <select id="selectByTypeCodeAndValues" resultMap="BaseResultMap">
        SELECT <include refid="Base_Column_List"/>
        FROM auth_lookup_value
        WHERE type_code = #{typeCode}
        AND item_value IN
        <foreach collection="values" item="val" open="(" separator="," close=")">
            #{val}
        </foreach>
        AND is_active = TRUE
    </select>

</mapper>