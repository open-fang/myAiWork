<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auth.management.mapper.QuestionnaireQuestionTextMapper">

    <resultMap id="BaseResultMap" type="com.auth.management.entity.QuestionnaireQuestionText">
        <id column="id" property="id"/>
        <result column="question_id" property="questionId"/>
        <result column="question_text" property="questionText"/>
        <result column="language" property="language"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="delete_flag" property="deleteFlag"/>
    </resultMap>

    <select id="selectByQuestionId" resultMap="BaseResultMap">
        SELECT id, question_id, question_text, language, created_by, created_time,
               updated_by, updated_time, delete_flag
        FROM questionnaire_question_texts
        WHERE question_id = #{questionId}
        AND delete_flag = 0
    </select>

    <delete id="deleteByQuestionId">
        DELETE FROM questionnaire_question_texts
        WHERE question_id = #{questionId}
    </delete>

    <select id="checkLanguageExists" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM questionnaire_question_texts
        WHERE question_id = #{questionId}
        AND language = #{language}
        AND delete_flag = 0
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

</mapper>