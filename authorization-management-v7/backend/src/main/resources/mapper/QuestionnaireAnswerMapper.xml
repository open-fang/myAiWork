<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auth.management.mapper.QuestionnaireAnswerMapper">

    <resultMap id="BaseResultMap" type="com.auth.management.entity.QuestionnaireAnswer">
        <id column="id" property="id"/>
        <result column="answer_code" property="answerCode"/>
        <result column="question_id" property="questionId"/>
        <result column="sort_order" property="sortOrder"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="delete_flag" property="deleteFlag"/>
    </resultMap>

    <select id="selectByQuestionId" resultMap="BaseResultMap">
        SELECT id, answer_code, question_id, sort_order, created_by, created_time,
               updated_by, updated_time, delete_flag
        FROM questionnaire_answers
        WHERE question_id = #{questionId}
        AND delete_flag = 0
        ORDER BY sort_order
    </select>

    <delete id="deleteByQuestionId">
        DELETE FROM questionnaire_answers
        WHERE question_id = #{questionId}
    </delete>

</mapper>