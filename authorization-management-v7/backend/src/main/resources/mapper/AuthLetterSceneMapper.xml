<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.auth.management.mapper.AuthLetterSceneMapper">

    <resultMap id="BaseResultMap" type="com.auth.management.entity.AuthLetterScene">
        <id column="id" property="id"/>
        <result column="auth_letter_id" property="authLetterId"/>
        <result column="scene_name" property="sceneName"/>
        <result column="industry" property="industry"/>
        <result column="business_scene" property="businessScene"/>
        <result column="decision_level" property="decisionLevel"/>
        <result column="specific_rule" property="specificRule"/>
        <result column="created_by" property="createdBy"/>
        <result column="created_time" property="createdTime"/>
        <result column="updated_by" property="updatedBy"/>
        <result column="updated_time" property="updatedTime"/>
        <result column="delete_flag" property="deleteFlag"/>
    </resultMap>

    <select id="checkSceneNameExists" resultType="java.lang.Integer">
        SELECT COUNT(*)
        FROM auth_letter_scenes
        WHERE delete_flag = 0
        AND auth_letter_id = #{authLetterId}
        AND scene_name = #{sceneName}
        <if test="excludeId != null">
            AND id != #{excludeId}
        </if>
    </select>

</mapper>